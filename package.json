{
  "name": "tech-market",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "migrate:create": "payload migrate:create",
    "migrate:run": "payload migrate",
    "migrate:fresh": "docker exec -it postgres_db psql -U postgres -c \"DROP DATABASE \\\"tech-market\\\";\" && docker exec -it postgres_db psql -U postgres -c \"CREATE DATABASE \\\"tech-market\\\";\" && rm -rf src/shared/api/migrations/* && payload migrate:create --name init && payload migrate",
    "seed": "tsx src/shared/api/payload/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@payloadcms/db-postgres": "^3.79.0",
    "@payloadcms/next": "^3.79.0",
    "@payloadcms/richtext-lexical": "^3.79.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "graphql": "^16.13.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0-canary.10",
    "payload": "^3.79.0",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
